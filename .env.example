# Секрет для подписи сессионных cookie (минимум 32 символа)
# На Vercel: Settings → Environment Variables → Production + Preview
AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Список пользователей: login:password через запятую
# Vercel не хранит пользователей — только эта переменная
# Без запятой и двоеточия внутри пароля (или используйте простые пароли)
# Пример: student1:pass1,student2:pass2
AUTH_USERS=student1:changeme,student2:changeme
